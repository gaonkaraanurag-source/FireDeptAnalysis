      <aliases enabled='yes' />
      <column datatype='datetime' hidden='true' name='[Alarm DateTime]' role='dimension' type='ordinal' />
      <column caption='Turnout Time' datatype='integer' name='[Alarm Handling (copy)_6827293849309188]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='IF NOT ISNULL([PSAP DateTime])&#10;AND NOT ISNULL([Enroute DateTime])&#10;THEN DATEDIFF(&apos;minute&apos;, [PSAP DateTime], [Enroute DateTime])&#10;END' />
      </column>
      <column datatype='string' hidden='true' name='[Cold Response]' role='dimension' type='nominal' />
      <column caption='Zipcode' datatype='string' datatype-customized='true' name='[Incident Full Address (copy)_6643331776897028]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL(REGEXP_EXTRACT(TRIM([Incident Full Address]), &quot;([0-9]{5})(?:-[0-9]{4})?$&quot;))&#10;OR REGEXP_EXTRACT(TRIM([Incident Full Address]), &quot;([0-9]{5})(?:-[0-9]{4})?$&quot;) = &quot;&quot;&#10;THEN &quot;0&quot;&#10;ELSE REGEXP_EXTRACT(TRIM([Incident Full Address]), &quot;([0-9]{5})(?:-[0-9]{4})?$&quot;)&#10;END' />
      </column>
      <column caption='State' datatype='string' name='[Incident Full Address (copy)_6643331777486853]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='REGEXP_EXTRACT(TRIM([Incident Full Address]), &quot;\s([A-Z]{2})\s+[0-9]{5}(?:-[0-9]{4})?$&quot;)' />
      </column>
      <column caption='City' datatype='string' name='[Incident Full Address (copy)_6643331777826822]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='REGEXP_EXTRACT(TRIM([Incident Full Address (copy)_6643331780681735]), &quot;\s([A-Z][A-Z\s]+)\s+[A-Z]{2}\s+[0-9]{5}(?:-[0-9]{4})?$&quot;)' />
      </column>
      <column caption='Incident Full Address Clean' datatype='string' name='[Incident Full Address (copy)_6643331780681735]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='UPPER(&#10;    TRIM(&#10;        REGEXP_REPLACE(&#10;            REGEXP_REPLACE(&#10;                REGEXP_REPLACE(&#10;                    [Incident Full Address],&#10;                    &quot;\s+&quot;,&#10;                    &quot; &quot;&#10;                ),&#10;                &quot;\s*/\s*&quot;,&#10;                &quot; / &quot;&#10;            ),&#10;            &quot;\s+AND\s+&quot;,&#10;            &quot; AND &quot;&#10;        )&#10;    )&#10;)' />
      </column>
      <column caption='Incident Full Address Clean (copy)' datatype='string' hidden='true' name='[Incident Full Address Clean (copy)_6643331781603336]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='UPPER(&#10;    TRIM(&#10;        REGEXP_REPLACE(&#10;            REGEXP_REPLACE(&#10;                REGEXP_REPLACE(&#10;                    [Incident Full Address],&#10;                    &quot;\s+&quot;,&#10;                    &quot; &quot;&#10;                ),&#10;                &quot;\s*/\s*&quot;,&#10;                &quot; / &quot;&#10;            ),&#10;            &quot;\s+AND\s+&quot;,&#10;            &quot; AND &quot;&#10;        )&#10;    )&#10;)' />
      </column>
      <column caption='Incident Year' datatype='string' datatype-customized='true' name='[Incident Number (copy)_6643331748151298 - Split 2]' role='dimension' type='nominal' user:SplitFieldIndex='2' user:SplitFieldOrigin='[federated.0frb52h0hdmqp91447pd90u8px1f].[Incident Number (copy)_6643331748151298]'>
        <calculation class='tableau' formula='IF REGEXP_MATCH(SPLIT([Incident Number (copy)_6643331767848963], &quot;-&quot;, 1), &quot;^[0-9]+$&quot;) THEN&#10;&#10;    IF LEN(SPLIT([Incident Number (copy)_6643331767848963], &quot;-&quot;, 1)) = 2 THEN&#10;        &quot;20&quot; + SPLIT([Incident Number (copy)_6643331767848963], &quot;-&quot;, 1)&#10;&#10;    ELSEIF LEN(SPLIT([Incident Number (copy)_6643331767848963], &quot;-&quot;, 1)) = 4&#10;        AND INT(SPLIT([Incident Number (copy)_6643331767848963], &quot;-&quot;, 1)) &lt;= 2025 THEN&#10;        SPLIT([Incident Number (copy)_6643331767848963], &quot;-&quot;, 1)&#10;&#10;    ELSEIF SPLIT([Incident Number (copy)_6643331767848963], &quot;-&quot;, 1) = &quot;22025&quot; THEN&#10;        &quot;2025&quot;&#10;&#10;    ELSE&#10;        &quot;0&quot;&#10;    END&#10;&#10;ELSE&#10;    &quot;0&quot;&#10;END' />
      </column>
      <column caption='Incident Number Actual' datatype='string' name='[Incident Number (copy)_6643331748151298 - Split 3]' role='dimension' type='nominal' user:SplitFieldIndex='3' user:SplitFieldOrigin='[federated.0frb52h0hdmqp91447pd90u8px1f].[Incident Number (copy)_6643331748151298]'>
        <calculation class='tableau' formula='IF ISNULL([Incident Number (copy)_6643331767848963]) &#10;OR TRIM(STR([Incident Number (copy)_6643331767848963])) = &quot;&quot;&#10;THEN &quot;0&quot;&#10;&#10;ELSEIF ISNULL(SPLIT(TRIM(STR([Incident Number (copy)_6643331767848963])), &quot;-&quot;, 2))&#10;OR TRIM(SPLIT(TRIM(STR([Incident Number (copy)_6643331767848963])), &quot;-&quot;, 2)) = &quot;&quot;&#10;THEN &quot;0&quot;&#10;&#10;ELSE TRIM(SPLIT(TRIM(STR([Incident Number (copy)_6643331767848963])), &quot;-&quot;, 2))&#10;&#10;END' />
      </column>
      <column caption='Incident Number Clean' datatype='string' name='[Incident Number (copy)_6643331767848963]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='REPLACE(&#10;    REPLACE(&#10;        REPLACE(&#10;            TRIM(STR([Incident Number])),&#10;            &quot;–&quot;, &quot;-&quot;&#10;        ),&#10;        &quot;—&quot;, &quot;-&quot;&#10;    ),&#10;    &quot;−&quot;, &quot;-&quot;&#10;)' />
      </column>
      <column caption='Incident Number Distinct Count' datatype='integer' name='[Incident Number Count (copy)_6643331746734081]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='COUNTD([Incident Number])' />
      </column>
      <column caption='Alarm Handling' datatype='integer' name='[Incident Number Distinct Count (copy)_6827293849198595]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='IF NOT ISNULL([PSAP DateTime])&#10;AND NOT ISNULL([Alarm DateTime])&#10;THEN DATEDIFF(&apos;minute&apos;, [PSAP DateTime], [Alarm DateTime])&#10;END' />
      </column>
      <column datatype='string' name='[Incident Type Category]' role='dimension' type='nominal' />
      <column datatype='string' hidden='true' name='[Incident Type]' role='dimension' type='nominal' />
      <column datatype='string' hidden='true' name='[Primary Station]' role='dimension' type='nominal' />
      <column caption='Geo State ' datatype='string' name='[State (copy)_6827293837049858]' role='dimension' semantic-role='[State].[Name]' type='nominal'>
        <calculation class='tableau' formula='REGEXP_EXTRACT(TRIM([Incident Full Address]), &quot;\s([A-Z]{2})\s+[0-9]{5}(?:-[0-9]{4})?$&quot;)' />
      </column>
      <column caption='Travel Time Data Check' datatype='string' name='[Travel Time (copy)_6827293851762695]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Arrival DateTime] &lt; [Enroute DateTime]&#10;THEN &quot;Invalid Travel Time&quot;&#10;ELSE &quot;Valid Travel Time&quot;&#10;END' />
      </column>
      <column caption='Travel Time' datatype='integer' name='[Turnout Time (copy)_6827293849694213]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='IF NOT ISNULL([Enroute DateTime])&#10;AND NOT ISNULL([Arrival DateTime])&#10;AND [Arrival DateTime] &gt;= [Enroute DateTime]&#10;THEN DATEDIFF(&apos;minute&apos;, [Enroute DateTime], [Arrival DateTime])&#10;END' />
      </column>
      <column caption='Turnout Time (copy)' datatype='integer' name='[Turnout Time (copy)_6827293849944070]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='IF NOT ISNULL([PSAP DateTime])&#10;AND NOT ISNULL([Alarm DateTime])&#10;THEN DATEDIFF(&apos;minute&apos;, [PSAP DateTime], [Arrival DateTime])&#10;END' />
      </column>
