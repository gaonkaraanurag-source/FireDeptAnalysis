      <aliases enabled='yes' />
      <column datatype='boolean' name='[Bad Response Time Flag]' role='dimension' semantic-role='' type='nominal' />
      <column caption='Total Incidents ' datatype='integer' name='[Calculation_2402240932139008]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Incident No Actual])' />
      </column>
      <column caption='Total Units Dispacted ' datatype='integer' name='[Calculation_2402240932327425]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Unit Call Sign])' />
      </column>
      <column caption='Avg Total Response Time' datatype='real' name='[Calculation_2402240932659202]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Total Response Time])' />
      </column>
      <column caption='Average Travel Time' datatype='real' name='[Calculation_2402240932765699]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Travel Time])' />
      </column>
      <column caption='Bad Response Time %' datatype='real' name='[Calculation_2402240932909060]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IIF([Bad Response Time Flag] = TRUE, 1, 0)) / COUNT([Incident No Actual])' />
      </column>
      <column caption='Cold Calls # ' datatype='integer' name='[Calculation_2809678888775680]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#10;IF [Cold Response] = &quot;Yes&quot; THEN [Incident No Actual] END&#10;)' />
      </column>
      <column caption='Cold Call %' datatype='real' default-format='*+0.0%;-0.0%' name='[Calculation_2809678889357313]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Cold Response] = &quot;Yes&quot; THEN [Incident No Actual] END)&#10;/&#10;COUNTD([Incident No Actual])' />
      </column>
      <column caption='YoY Incident % Diff' datatype='real' default-format='p0.00%' name='[Calculation_2809678891253762]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_2809678899408904] - [Calculation_2914063804358656])&#10;/&#10;([Calculation_2914063804358656])' />
      </column>
      <column caption='Current Year' datatype='datetime' name='[Calculation_2809678897295365]' role='dimension' type='quantitative'>
        <calculation class='tableau' formula='DATETRUNC(&apos;year&apos;,[PSAP DateTime])' />
      </column>
      <column caption='# Incidents 2025' datatype='integer' name='[Calculation_2809678899408904]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#10;    IF YEAR([PSAP DateTime]) = YEAR(TODAY()) - 1&#10;    THEN [Incident No Actual]&#10;    END&#10;)' />
      </column>
      <column caption='# Incidents 2024' datatype='integer' name='[Calculation_2914063804358656]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#10;    IF YEAR([PSAP DateTime]) = YEAR(TODAY()) - 2&#10;    THEN [Incident No Actual]&#10;    END&#10;)' />
      </column>
      <column caption='# Incidents 2023 ' datatype='integer' name='[Calculation_2914063808720898]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#10;    IF YEAR([PSAP DateTime]) = YEAR(TODAY()) - 3&#10;    THEN [Incident No Actual]&#10;    END&#10;)' />
      </column>
